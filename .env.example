# ============================================================
# AgentCrew MCN Configuration
# Copy to .env and fill in your credentials
# ============================================================

# ── LLM API (required, pick one) ────────────────────────────
# DeepSeek (default)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI
# OPENAI_API_KEY=sk-your-key-here

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Ollama (local, no key needed)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── RAG Embedding (optional) ────────────────────────────────
# SiliconFlow BGE: https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# ── Platforms ────────────────────────────────────────────────

# Juejin 掘金 (Cookie from browser)
JUEJIN_COOKIE=

# Zhihu 知乎 (Playwright browser automation, no env needed)
# ZHIHU_COOKIE=

# Dev.to (API key: https://dev.to/settings/extensions)
DEVTO_API_KEY=

# CSDN (Cookie from browser)
CSDN_COOKIE=

# WeChat 微信公众号 (AppID + Secret)
# Get from: https://mp.weixin.qq.com → 开发 → 基本配置
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# SegmentFault 思否 (Cookie from browser)
SEGMENTFAULT_COOKIE=

# X/Twitter (OAuth 1.0a)
# Get from: https://developer.twitter.com/en/portal
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Xiaohongshu 小红书 (Cookie from browser)
XIAOHONGSHU_COOKIE=

# Medium (API key: Settings → Integration tokens)
MEDIUM_API_KEY=
